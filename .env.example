# Copy this file to .env and adjust if needed.
# All heavy model/cache storage is redirected off C: (only 43GB free there) to D:.

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Smaller/faster model for routing + CRAG grading (simple structured-extraction
# tasks) -- final generation still uses GROQ_MODEL above for quality.
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Tavily (https://tavily.com) -- web search fallback when the CSB corpus has
# no confident answer. Optional: if unset, the app just declines instead.
TAVILY_API_KEY=

# HuggingFace / sentence-transformers cache (embeddings + reranker downloads)
# NOTE: D: only has 9GB free (cluttered with older unrelated projects), while C: has
# 42GB free. Redirected here instead, to a clearly labeled folder, so nothing is
# competing with existing D: data.
HF_HOME=C:\ai-cache\hf-cache

# Embedding model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Cross-encoder reranking -- set to false on memory-constrained deployments (the
# reranker model alone is ~1.1GB in fp32). See config.py for the behavior tradeoff.
ENABLE_RERANKER=true

# Paths
DATA_DIR=D:\chem project\data
RAW_PDF_DIR=D:\chem project\data\raw_pdfs
PROCESSED_DIR=D:\chem project\data\processed
CHROMA_DIR=D:\chem project\chroma_db
CHROMA_COLLECTION=csb_reports

# pip cache
PIP_CACHE_DIR=C:\ai-cache\pip-cache
